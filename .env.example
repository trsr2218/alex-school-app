# Port the server listens on (most free hosts set this for you automatically).
PORT=3000

# How long a login session stays valid before the user must sign in again.
SESSION_TTL_HOURS=12

# Optional: only set these if you want MySQL-backed auth instead of the
# built-in JSON file store. Leave all of them unset to run on the
# zero-cost/JSON-only path (recommended for free-tier hosting).
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=vfu_db
